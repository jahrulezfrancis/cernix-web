# =============================================================================
# Cernix production environment template (Alibaba Cloud ECS)
# =============================================================================
# Setup on the server ONLY:
#   cp .env.production.example .env.production
#   chmod 600 .env.production
#   # Edit with a non-logging editor. Never paste secrets into GitHub, chat,
#   # screenshots, demo video, or shell history.
#
# Never commit .env.production. Rotate any secret that is accidentally exposed.
# Never run `docker compose config` in a way that publishes expanded secret
# values into CI logs or public reports.
#
# Replace PUBLIC_IP_PLACEHOLDER with the ECS public IPv4 address until a domain
# and TLS certificate are available.
# =============================================================================

# Optional host publish for Nginx. Default 80 (ECS). Local rootless Docker may
# need CERNIX_HTTP_PORT=8080 because privileged ports require elevated rights.
# CERNIX_HTTP_PORT=80

# -----------------------------------------------------------------------------
# PostgreSQL (container init + application URL)
# -----------------------------------------------------------------------------
# Use a strong unique password. If the password contains reserved URL characters
# (@ : / ? # [ ] %), percent-encode them inside DATABASE_URL.
POSTGRES_DB=cernix
POSTGRES_USER=cernix
POSTGRES_PASSWORD=replace_with_strong_value

# Host `postgres` is the Compose service name on the private backend network.
DATABASE_URL=postgresql://cernix:replace_with_strong_value@postgres:5432/cernix
DATABASE_POOL_MAX=5

# -----------------------------------------------------------------------------
# Authentication (GitHub OAuth)
# -----------------------------------------------------------------------------
# Callback URL registered in the GitHub OAuth App MUST be exactly:
#   http://PUBLIC_IP_PLACEHOLDER/api/auth/github/callback
# Homepage URL:
#   http://PUBLIC_IP_PLACEHOLDER
#
# IMPORTANT LIMITATION: session and OAuth cookies set Secure when NODE_ENV is
# production. Browsers will not store/send Secure cookies over plain HTTP.
# Public-IP HTTP deployment can serve health checks and static pages, but
# GitHub sign-in will not work reliably until a domain + HTTPS are configured.
# Do not weaken Secure cookies for the hackathon IP step.
AUTH_SECRET=replace_with_at_least_32_random_characters
AUTH_URL=http://PUBLIC_IP_PLACEHOLDER
AUTH_GITHUB_CLIENT_ID=replace_with_github_oauth_client_id
AUTH_GITHUB_CLIENT_SECRET=replace_with_github_oauth_client_secret

# -----------------------------------------------------------------------------
# Qwen Cloud / DashScope (workers)
# -----------------------------------------------------------------------------
# Secret name in this codebase is QWEN_API_KEY (not DASHSCOPE_API_KEY).
QWEN_API_KEY=replace_with_dashscope_api_key
# Frankfurt / international keys: use the intl origin (allowlisted in code).
QWEN_API_ORIGIN=https://dashscope-intl.aliyuncs.com
QWEN_MODEL_ID=qwen-plus
QWEN_PROMPT_VERSION=planning-v1
QWEN_REQUEST_TIMEOUT_MS=30000
QWEN_PLANNING_DEADLINE_MS=120000
QWEN_MAX_OUTPUT_TOKENS=4096
QWEN_MAX_CONTEXT_BYTES=65536
QWEN_MAX_RESPONSE_BYTES=131072

# -----------------------------------------------------------------------------
# Optional GitHub API token for higher snapshot rate limits (not OAuth)
# -----------------------------------------------------------------------------
# Scope: public_repo read is enough for public repositories; leave empty for
# anonymous public snapshots with lower rate limits.
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# GitHub snapshot bounds (runtime non-secret)
# -----------------------------------------------------------------------------
GITHUB_API_VERSION=2026-03-10
GITHUB_REQUEST_TIMEOUT_MS=10000
GITHUB_SNAPSHOT_DEADLINE_MS=90000
GITHUB_MAX_REQUESTS_AUTHENTICATED=2000
GITHUB_MAX_REQUESTS_ANONYMOUS=50
GITHUB_MAX_INSPECTED_ENTRIES=10000
GITHUB_MAX_ADMITTED_FILES=1500
GITHUB_MAX_FILE_BYTES=262144
GITHUB_MAX_TOTAL_TEXT_BYTES=10485760
GITHUB_MAX_LINES_PER_FILE=20000
GITHUB_MAX_TREE_DEPTH=64
GITHUB_MAX_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Worker leases / retries (runtime non-secret; owners also set in Compose)
# -----------------------------------------------------------------------------
CERNIX_SNAPSHOT_LEASE_SECONDS=120
CERNIX_SNAPSHOT_HEARTBEAT_SECONDS=30
CERNIX_SNAPSHOT_POLL_MS=1000
CERNIX_SNAPSHOT_MAX_ATTEMPTS=4
CERNIX_SNAPSHOT_RETRY_BASE_SECONDS=5
CERNIX_SNAPSHOT_RETRY_MAX_SECONDS=300

CERNIX_PLANNING_LEASE_SECONDS=120
CERNIX_PLANNING_HEARTBEAT_SECONDS=30
CERNIX_PLANNING_POLL_MS=1000
CERNIX_PLANNING_MAX_ATTEMPTS=4
CERNIX_PLANNING_RETRY_BASE_SECONDS=5
CERNIX_PLANNING_RETRY_MAX_SECONDS=300

CERNIX_EVIDENCE_LEASE_SECONDS=180
CERNIX_EVIDENCE_HEARTBEAT_SECONDS=45
CERNIX_EVIDENCE_POLL_MS=1000
CERNIX_EVIDENCE_MAX_ATTEMPTS=4
CERNIX_EVIDENCE_RETRY_BASE_SECONDS=5
CERNIX_EVIDENCE_RETRY_MAX_SECONDS=300
CERNIX_EVIDENCE_MAX_EXCERPTS=12
CERNIX_EVIDENCE_MAX_MATCHES_PER_TERM=4
CERNIX_EVIDENCE_EXCERPT_CONTEXT_LINES=3
CERNIX_EVIDENCE_MAX_EXCERPT_BYTES=2048
CERNIX_EVIDENCE_MAX_CONTEXT_BYTES=65536

CERNIX_SKEPTIC_LEASE_SECONDS=180
CERNIX_SKEPTIC_HEARTBEAT_SECONDS=45
CERNIX_SKEPTIC_POLL_MS=1000
CERNIX_SKEPTIC_MAX_ATTEMPTS=4
CERNIX_SKEPTIC_RETRY_BASE_SECONDS=5
CERNIX_SKEPTIC_RETRY_MAX_SECONDS=300
CERNIX_SKEPTIC_MAX_CONTEXT_BYTES=48000
CERNIX_MAX_REINVESTIGATION_CYCLES=1

CERNIX_JUDGE_LEASE_SECONDS=180
CERNIX_JUDGE_HEARTBEAT_SECONDS=45
CERNIX_JUDGE_POLL_MS=1000
CERNIX_JUDGE_MAX_ATTEMPTS=4
CERNIX_JUDGE_RETRY_BASE_SECONDS=5
CERNIX_JUDGE_RETRY_MAX_SECONDS=300
CERNIX_JUDGE_MAX_CONTEXT_BYTES=64000

# Do NOT set these in production:
# CERNIX_INTEGRATION_TEST_DATABASE
# CERNIX_QWEN_LIVE_SMOKE
# CERNIX_GITHUB_LIVE_SMOKE
# GITHUB_LIVE_OWNER / GITHUB_LIVE_REPOSITORY / GITHUB_LIVE_COMMIT
